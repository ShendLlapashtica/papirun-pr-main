{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/push.ts": {
      "memory": 128
    },
    "api/place-order.ts": {
      "memory": 128
    },
    "api/driver-orders.ts": {
      "memory": 128
    },
    "api/auth/send-tan.ts": {
      "memory": 128
    },
    "api/auth/verify-tan.ts": {
      "memory": 128
    },
    "api/keep-alive.ts": {
      "memory": 128
    }
  },
  "crons": [
    {
      "path": "/api/keep-alive",
      "schedule": "0 9 * * *"
    }
  ]
}
